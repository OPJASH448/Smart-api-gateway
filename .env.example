# Smart API Gateway - Environment Variables Template
# Copy to .env and modify values as needed

# ────────────────────────────────────────────────────────────────────────────
# Gateway Configuration
# ────────────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# ────────────────────────────────────────────────────────────────────────────
# Service URLs (for Docker, use container names; for local, use localhost)
# ────────────────────────────────────────────────────────────────────────────

# Docker Compose
AUTH_SERVICE_URL=http://auth:9001
CHAT_SERVICE_URL=http://chat:9002
AI_SERVICE_URL=http://ai:9003
PRODUCTS_SERVICE_URL=http://products:9004

# Local Development (comment out for docker)
# AUTH_SERVICE_URL=http://localhost:9001
# CHAT_SERVICE_URL=http://localhost:9002
# AI_SERVICE_URL=http://localhost:9003
# PRODUCTS_SERVICE_URL=http://localhost:9004

# ────────────────────────────────────────────────────────────────────────────
# HTTP Client Settings
# ────────────────────────────────────────────────────────────────────────────
REQUEST_TIMEOUT=30.0
CONNECT_TIMEOUT=5.0
POOL_MAX_CONNECTIONS=100
POOL_MAX_KEEPALIVE=20

# ────────────────────────────────────────────────────────────────────────────
# Rate Limiting
# ────────────────────────────────────────────────────────────────────────────
RATE_LIMITER_ENABLED=true
RATE_LIMITER_ALGORITHM=token_bucket
# Algorithm options: token_bucket (burst-tolerant) | sliding_window (strict)

RATE_LIMITER_RATE=100
RATE_LIMITER_CAPACITY=100
RATE_LIMITER_WINDOW_SECONDS=60

# Whitelist IPs that bypass rate limiting (comma-separated)
# RATE_LIMITER_WHITELIST=127.0.0.1,0.0.0.0

# ────────────────────────────────────────────────────────────────────────────
# Redis (Cache & Rate Limiter State)
# ────────────────────────────────────────────────────────────────────────────

# Docker Compose
REDIS_URL=redis://redis:6379

# Local Development (comment out for docker)
# REDIS_URL=redis://localhost:6379

# Advanced (optional)
# REDIS_URL=redis://:password@host:port/db

# ────────────────────────────────────────────────────────────────────────────
# Database (Request Logging)
# ────────────────────────────────────────────────────────────────────────────

# Docker Compose
DATABASE_URL=postgresql://gateway:gateway_password@postgres:5432/gateway_logs

# Local Development (comment out for docker)
# DATABASE_URL=postgresql://gateway:gateway_password@localhost:5432/gateway_logs

# Format: postgresql://user:password@host:port/database

# ────────────────────────────────────────────────────────────────────────────
# Production Settings (uncomment when deploying)
# ────────────────────────────────────────────────────────────────────────────

# ENVIRONMENT=production
# LOG_LEVEL=WARNING
# RATE_LIMITER_RATE=1000
# REQUEST_TIMEOUT=60.0
